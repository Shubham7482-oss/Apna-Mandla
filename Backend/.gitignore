# ─────────────────────────────────────────────────────────────────────────────
# Apna Mandla Backend — .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── SECRETS — NEVER COMMIT THESE ─────────────────────────────────────────────
.env
.env.*
!.env.example            # the template is safe to commit

# Firebase service-account credentials
firebase-credentials.json
*-credentials.json
*-service-account.json
*-adminsdk-*.json

# ─────────────────────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Distribution / packaging
build/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ─────────────────────────────────────────────────────────────────────────────
# Virtual environments
# ─────────────────────────────────────────────────────────────────────────────
.venv/
venv/
ENV/
env/
env.bak/
venv.bak/

# ─────────────────────────────────────────────────────────────────────────────
# Testing & coverage
# ─────────────────────────────────────────────────────────────────────────────
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
.pytest_cache/
.hypothesis/

# ─────────────────────────────────────────────────────────────────────────────
# Database files (local dev only)
# ─────────────────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ─────────────────────────────────────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────────────────────────────────────
*.log
backend.log
logs/

# ─────────────────────────────────────────────────────────────────────────────
# Uploads & static generated files
# ─────────────────────────────────────────────────────────────────────────────
static/uploads/

# ─────────────────────────────────────────────────────────────────────────────
# IDE / OS
# ─────────────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ─────────────────────────────────────────────────────────────────────────────
# Type checkers & linters
# ─────────────────────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/

# ─────────────────────────────────────────────────────────────────────────────
# PyInstaller
# ─────────────────────────────────────────────────────────────────────────────
*.manifest
*.spec

# ─────────────────────────────────────────────────────────────────────────────
# mkdocs
# ─────────────────────────────────────────────────────────────────────────────
/site
